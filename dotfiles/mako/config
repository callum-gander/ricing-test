# ~/.config/mako/config — Editorial Paper (warm light)
# Portable: works on any distro with mako. Reload after edits: makoctl reload

font=Noto Sans 11
background-color=#faf8f2
text-color=#1b1916
border-color=#d9d2c5
progress-color=over #ece7dd
border-radius=0
border-size=1
width=340
height=140
padding=14
margin=12
default-timeout=6000
anchor=top-right

[urgency=high]
border-color=#a3432f
text-color=#1b1916
default-timeout=0
